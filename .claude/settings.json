{
  "permissions": {
    "allow": [
      "Bash(conda run -n tckdb_env pytest *)",
      "Bash(conda run -n tckdb_env alembic *)",
      "Bash(conda run -n tckdb_env python *)",
      "Bash(conda run -n tckdb_env *)",
      "Bash(docker compose *)",
      "Bash(ls *)",
      "Bash(git *)",
      "Read(*)",
      "Edit(app/**)",
      "Edit(tests/**)",
      "Edit(alembic/**)",
      "Write(app/**)",
      "Write(tests/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [[ \"$file\" == *.py ]]; then conda run -n tckdb_env black --quiet \"$file\" 2>/dev/null; fi"
          }
        ]
      }
    ]
  }
}
